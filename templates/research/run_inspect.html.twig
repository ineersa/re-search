{% extends 'base.html.twig' %}

{% block title %}Run inspect · {{ run.query|length > 40 ? run.query|slice(0, 40) ~ '…' : run.query }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github-dark.min.css">
{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#0a0a0a] text-gray-200">
    <div class="mx-auto max-w-5xl px-4 py-8">
        <header class="mb-8 flex flex-wrap items-center justify-between gap-4 border-b border-[#333] pb-6">
            <div>
                <a href="/" class="text-sm text-gray-500 hover:text-gray-300">← re-search</a>
                <h1 class="mt-2 text-xl font-semibold text-white">Run inspect</h1>
                <p class="mt-1 font-mono text-sm text-gray-400 break-all">{{ run.runUuid }}</p>
            </div>
            <div class="flex flex-wrap gap-3 text-sm">
                <span class="rounded px-2 py-1 font-medium
                    {% if run.status == 'completed' %}bg-emerald-900/50 text-emerald-300
                    {% elseif run.status == 'running' %}bg-amber-900/50 text-amber-300
                    {% elseif run.status == 'failed' or run.status == 'timed_out' %}bg-red-900/50 text-red-300
                    {% else %}bg-gray-700/50 text-gray-300{% endif %}">
                    {{ run.status.value }}
                </span>
                <span class="text-gray-500">{{ run.tokenBudgetUsed }} / {{ run.tokenBudgetHardCap }} tokens</span>
                {% if run.loopDetected %}<span class="text-amber-400">Loop detected</span>{% endif %}
                {% if run.answerOnlyTriggered %}<span class="text-amber-400">Answer-only</span>{% endif %}
            </div>
        </header>

        <section class="mb-8 rounded-lg border border-[#333] bg-[#111] p-4">
            <h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-gray-500">Query</h2>
            <p class="font-mono text-sm text-gray-300">{{ run.query }}</p>
            <div class="mt-3 flex flex-wrap gap-4 text-xs text-gray-500">
                <span>Created: {{ run.createdAt|date('Y-m-d H:i:s') }}</span>
                {% if run.completedAt %}<span>Completed: {{ run.completedAt|date('Y-m-d H:i:s') }}</span>{% endif %}
                {% if run.failureReason %}<span class="text-red-400">{{ run.failureReason }}</span>{% endif %}
            </div>
        </section>

        {% if run.finalAnswerMarkdown %}
        <section class="mb-8 rounded-lg border border-[#333] bg-[#111] p-4">
            <h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-gray-500">Final answer</h2>
            <div class="prose prose-invert prose-sm max-w-none font-mono text-sm text-gray-300 whitespace-pre-wrap">{{ run.finalAnswerMarkdown|e }}</div>
        </section>
        {% endif %}

        <section class="mb-8">
            <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-gray-500">Steps ({{ stepsForView|length }})</h2>
            <div class="space-y-3">
                {% for item in stepsForView %}
                {% set step = item.step %}
                <article class="rounded-lg border border-[#333] bg-[#141414] overflow-hidden">
                    <div class="flex flex-wrap items-center gap-2 border-b border-[#222] px-4 py-3">
                        <span class="rounded px-2 py-0.5 text-xs font-medium
                            {% if step.type == 'llm_invocation' %}bg-violet-900/50 text-violet-300
                            {% elseif step.type == 'tool_succeeded' %}bg-emerald-900/50 text-emerald-300
                            {% elseif step.type == 'tool_failed' %}bg-red-900/50 text-red-300
                            {% elseif step.type == 'turn_started' %}bg-blue-900/50 text-blue-300
                            {% elseif step.type == 'token_snapshot' %}bg-cyan-900/50 text-cyan-300
                            {% elseif step.type == 'run_started' or step.type == 'assistant_final' %}bg-gray-700/50 text-gray-300
                            {% else %}bg-amber-900/50 text-amber-300{% endif %}">
                            {{ step.type }}
                        </span>
                        <span class="text-xs text-gray-500">#{{ step.sequence }} · Turn {{ step.turnNumber }}</span>
                        {% if step.toolName %}<span class="text-xs text-gray-400">· {{ step.toolName }}</span>{% endif %}
                        {% if step.promptTokens is not null %}<span class="text-xs text-gray-500">· {{ step.promptTokens }}+{{ step.completionTokens }} tokens</span>{% endif %}
                    </div>
                    <div class="px-4 py-2">
                        <p class="text-sm text-gray-400">{{ step.summary }}</p>
                    </div>
                    {% if item.prettyMessages is not empty or item.prettyTools is not empty or item.prettyRawMetadata is not empty or item.prettyToolArgs is not empty or item.prettyPayload is not empty %}
                    <div class="border-t border-[#222] px-4 pb-4 pt-2">
                        {% if item.prettyTools is not empty %}
                        <details class="group mb-2">
                            <summary class="cursor-pointer text-xs font-medium text-gray-500 hover:text-gray-400">Tools (definitions)</summary>
                            <pre class="mt-2 overflow-x-auto rounded bg-[#0a0a0a] p-3 text-xs text-gray-300"><code class="language-json">{{ item.prettyTools|e }}</code></pre>
                        </details>
                        {% endif %}
                        {% if item.prettyRawMetadata is not empty %}
                        <details class="group mb-2" {% if step.type == 'assistant_empty' %}open{% endif %}>
                            <summary class="cursor-pointer text-xs font-medium text-gray-500 hover:text-gray-400">Raw model metadata</summary>
                            <pre class="mt-2 overflow-x-auto rounded bg-[#0a0a0a] p-3 text-xs text-gray-300"><code class="language-json">{{ item.prettyRawMetadata|e }}</code></pre>
                        </details>
                        {% endif %}
                        {% if item.prettyMessages is not empty %}
                        <details class="group mb-2">
                            <summary class="cursor-pointer text-xs font-medium text-gray-500 hover:text-gray-400">Messages (request)</summary>
                            <pre class="mt-2 overflow-x-auto rounded bg-[#0a0a0a] p-3 text-xs text-gray-300"><code class="language-json">{{ item.prettyMessages|e }}</code></pre>
                        </details>
                        {% endif %}
                        {% if item.prettyToolArgs is not empty %}
                        <details class="group mb-2" {% if step.type == 'tool_succeeded' or step.type == 'tool_failed' %}open{% endif %}>
                            <summary class="cursor-pointer text-xs font-medium text-gray-500 hover:text-gray-400">Tool arguments</summary>
                            <pre class="mt-2 overflow-x-auto rounded bg-[#0a0a0a] p-3 text-xs text-gray-300"><code class="language-json">{{ item.prettyToolArgs|e }}</code></pre>
                        </details>
                        {% endif %}
                        {% if item.prettyPayload is not empty %}
                        <details class="group" {% if step.type == 'llm_invocation' and item.prettyMessages is empty %}open{% endif %}>
                            <summary class="cursor-pointer text-xs font-medium text-gray-500 hover:text-gray-400">
                                {% if step.type == 'llm_invocation' %}Request / Response (full payload){% elseif step.type == 'tool_succeeded' or step.type == 'tool_failed' %}Result{% else %}Details{% endif %}
                            </summary>
                            <pre class="mt-2 overflow-x-auto rounded bg-[#0a0a0a] p-3 text-xs text-gray-300"><code class="language-json">{{ item.prettyPayload|e }}</code></pre>
                        </details>
                        {% endif %}
                    </div>
                    {% endif %}
                </article>
                {% else %}
                <p class="text-sm text-gray-500">No steps recorded.</p>
                {% endfor %}
            </div>
        </section>
    </div>
</div>
{% block javascripts %}
    {{ parent() }}
    <script type="module">
        import hljs from 'highlight.js';
        document.querySelectorAll('pre code').forEach((el) => hljs.highlightElement(el));
    </script>
{% endblock %}
{% endblock %}
