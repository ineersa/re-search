{% extends 'base.html.twig' %}

{% block title %}re-search{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github-dark.min.css">
{% endblock %}

{% block body %}
    <div
        class="flex flex-col min-h-screen bg-[#0a0a0a]"
        data-controller="research-ui"
        data-research-ui-submit-url-value="{{ path('app_research_submit') }}"
        data-research-ui-history-url-value="{{ path('app_research_list') }}"
        data-research-ui-run-url-value="{{ path('app_research_show', { id: '__ID__' }) }}"
        data-research-ui-mercure-auth-url-value="{{ path('app_research_mercure_auth', { id: '__ID__' }) }}"
    >
        <div class="flex-1 flex flex-col lg:flex-row">
            {# Mobile sidebar toggle #}
            <button
                class="fixed top-4 left-4 z-50 flex items-center justify-center w-10 h-10 rounded-lg bg-[#1a1a1a] border border-[#333] text-white lg:hidden"
                data-action="click->research-ui#toggleSidebar"
                aria-label="Toggle history"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>

            {# Sidebar / History #}
            <aside
                class="fixed inset-y-0 left-0 z-40 w-[290px] transform -translate-x-full bg-[#0a0a0a] p-5 border-r border-[#222] transition-transform duration-300 lg:static lg:translate-x-0 lg:border-r-0 lg:w-[290px] lg:shrink-0"
                data-research-ui-target="sidebar"
            >
                <div class="flex items-center justify-between mb-5">
                    <a href="/" class="inline-block no-underline text-white font-medium text-2xl tracking-widest">re-search</a>
                    <button
                        class="flex items-center justify-center w-8 h-8 text-gray-400 hover:text-white lg:hidden"
                        data-action="click->research-ui#toggleSidebar"
                        aria-label="Close history"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
                <p class="mb-2 text-xs uppercase tracking-wider text-gray-500">History</p>
                <div class="grid gap-2" data-research-ui-target="history"></div>
            </aside>

            {# Overlay for mobile sidebar #}
            <div
                class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden"
                data-research-ui-target="sidebarOverlay"
                data-action="click->research-ui#toggleSidebar"
            ></div>

            <main class="flex-1 p-4 pt-16 lg:pt-5 lg:p-[2.5rem_clamp(1rem,3.5vw,3rem)]">
                <header class="mx-auto mt-4 mb-8 max-w-[820px] text-center transition-all duration-300 lg:mt-[12vh] lg:-translate-x-[145px]" data-research-ui-target="hero">
                    <h1 class="m-0 text-[clamp(1.6rem,3.5vw,2.4rem)] tracking-tight">re-search</h1>
                    <p class="mt-2 text-base text-gray-500">Ask, trace, verify.</p>
                </header>

                <section class="mx-auto w-full max-w-[820px] transition-transform duration-300 query-area lg:-translate-x-[145px]">
                    <form class="p-4 shadow-[0_18px_54px_rgba(0,0,0,0.5)]" data-research-ui-target="form" data-action="submit->research-ui#submit">
                        <div class="grid grid-cols-1 gap-2 sm:grid-cols-[1fr_auto] sm:gap-3 sm:items-center">
                            <input
                                id="query"
                                class="w-full border border-[#444] bg-[#1a1a1a] p-3 text-gray-100 outline-none focus:border-gray-300 focus:ring-1 focus:ring-gray-300 placeholder-gray-600"
                                type="text"
                                placeholder="Ask anything..."
                                data-research-ui-target="input"
                            >
                            <button class="flex cursor-pointer items-center justify-center border-none bg-white p-3 font-semibold text-black transition-colors hover:bg-gray-200" type="submit" aria-label="Search">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </button>
                        </div>
                    </form>
                </section>

                <section class="mx-auto w-full max-w-[1020px] overflow-hidden border border-[#333] bg-[#111]/90 results mt-8 lg:-translate-x-[145px]" data-research-ui-target="results" hidden>
                    <div class="flex flex-col gap-4 border-b border-[#333] p-3 sm:flex-row sm:justify-between sm:items-center sm:p-4">
                        <p class="m-0 text-sm" data-research-ui-target="queryLine">No active query yet.</p>
                        <div class="flex items-center gap-3">
                            <p class="m-0 text-sm text-gray-500" data-research-ui-target="status">Waiting for input</p>
                            <button
                                type="button"
                                class="border border-[#444] bg-transparent px-3 py-1.5 text-xs text-gray-400 hover:text-white hover:border-gray-500 transition-colors cursor-pointer"
                                data-research-ui-target="cancelBtn"
                                data-action="click->research-ui#cancelRun"
                                hidden
                            >
                                Stop
                            </button>
                        </div>
                    </div>

                    <div class="flex gap-4 border-b border-[#333] px-4 pt-4" data-research-ui-target="tabs" data-active-tab="answer">
                        <button class="border-none bg-transparent pb-3 font-semibold text-white border-b-2 border-white cursor-pointer tab-btn" type="button" data-tab="answer" data-action="click->research-ui#switchTab">Answer</button>
                        <button class="border-none bg-transparent pb-3 font-semibold text-gray-500 border-b-2 border-transparent hover:text-white cursor-pointer tab-btn" type="button" data-tab="trace" data-action="click->research-ui#switchTab">Trace</button>
                    </div>

                    <article class="max-h-[80vh] overflow-auto p-3 sm:p-4 font-mono text-sm" data-research-ui-target="answer">
                        <div class="grid gap-2" data-research-ui-target="stream">
                            <article class="border border-[#333] bg-[#1a1a1a] p-3 stream-row">
                                <p class="m-0 text-xs uppercase tracking-wider text-gray-500">intro</p>
                                <p class="mt-1 leading-relaxed text-gray-300">Tool activity appears here while the agent runs.</p>
                            </article>
                        </div>
                        <div class="flex justify-end mb-2">
                            <button
                                type="button"
                                class="border border-[#444] bg-transparent px-2 py-1 text-xs text-gray-500 hover:text-white hover:border-gray-500 transition-colors cursor-pointer"
                                data-research-ui-target="renderModeToggle"
                                data-action="click->research-ui#toggleRenderMode"
                                hidden
                            >
                                Raw
                            </button>
                        </div>
                        <div class="grid gap-2 answer-body" data-research-ui-target="answerBody"></div>
                    </article>

                    <article class="max-h-[80vh] overflow-auto p-3 sm:p-4 font-mono text-sm" data-research-ui-target="trace" hidden>
                        <div class="grid gap-2" data-research-ui-target="traceBody">
                            <p class="m-0 text-gray-500">No tool calls yet.</p>
                        </div>
                    </article>
                </section>
            </main>
        </div>

        {# Footer #}
        <footer class="bg-[#0a0a0a] py-6 flex flex-col items-center border-t border-[#222]">
            <div class="mb-3 flex space-x-4">
                <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="mailto:ineersa.c@gmail.com">
                    <span class="sr-only">mail</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="fill-current text-gray-400 hover:text-white h-6 w-6 transition-colors">
                        <title>Mail</title>
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                    </svg>
                </a>
                <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="https://github.com/ineersa">
                    <span class="sr-only">github</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="fill-current text-gray-400 hover:text-white h-6 w-6 transition-colors">
                        <title>Github</title>
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
                    </svg>
                </a>
                <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/in/illia-vasylevskyi-b7353558/">
                    <span class="sr-only">linkedin</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="fill-current text-gray-400 hover:text-white h-6 w-6 transition-colors">
                        <title>Linkedin</title>
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                    </svg>
                </a>
            </div>
            <div class="mb-2 flex space-x-2 text-sm text-gray-500">
                <div>Illia Vasylevskyi</div>
                <div>•</div>
                <div>© {{ "now"|date("Y") }}</div>
                <div>•</div>
                <a href="/" class="hover:text-gray-300">re-search</a>
            </div>
        </footer>
    </div>
{% endblock %}
